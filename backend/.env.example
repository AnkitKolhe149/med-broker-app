# NeonDB connection string
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# For production, use Neon's pooled connection string for better performance
# Pooled URL format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&pgbouncer=true&connection_limit=10
DATABASE_URL="postgresql://user:password@ep-your-endpoint.neon.tech/med_broker?sslmode=require"

# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Configuration
# Generate secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Exchange Rate API (Optional)
EXCHANGE_RATE_API_KEY="your-api-key-for-exchange-rate-service"
EXCHANGE_RATE_BASE="USD"

# CORS Configuration - comma-separated allowed origins
CORS_ORIGIN="http://localhost:5173,http://localhost:3000,http://localhost:3001"

# Logging
LOG_LEVEL="info"
