generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  VENDOR
}

enum VendorType {
  MANUFACTURER
  DISTRIBUTOR
  PHARMACY
}

enum BuyerType {
  RETAIL
  WHOLESALE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum PaymentStatus {
  INITIATED
  SUCCEEDED
  FAILED
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  mobile            String?
  passwordHash      String
  name              String?
  role              UserRole  @default(CUSTOMER)
  isProfileComplete Boolean   @default(false)
  orders            Order[]
  vendor            Vendor?
  customer          Customer?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([createdAt])
}

model Vendor {
  id                 String             @id @default(uuid())
  userId             String             @unique
  companyName        String
  vendorType         VendorType
  country            String
  state              String
  gstinNumber        String             @unique
  drugLicenseNumber  String             @unique
  businessAddress    String
  bankAccountDetails Json?
  contactPersonName  String
  contactNumber      String
  verificationStatus VerificationStatus @default(PENDING)
  user               User               @relation(fields: [userId], references: [id])
  inventory          Inventory[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([verificationStatus])
  @@index([updatedAt])
}

model Customer {
  id              String    @id @default(uuid())
  userId          String    @unique
  fullName        String
  buyerType       BuyerType
  businessName    String?
  gstin           String?
  country         String
  city            String
  deliveryAddress String
  contactNumber   String
  user            User      @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Medicine {
  id                   String      @id @default(uuid())
  name                 String
  description          String?
  priceCents           Int
  wholesalePriceCents  Int?
  bulkMinQty           Int?
  bulkPriceCents       Int?
  requiresPrescription Boolean     @default(false)
  inventory            Inventory[]
  orderItems           OrderItem[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([updatedAt])
}

model Inventory {
  id         String   @id @default(uuid())
  medicineId String
  vendorId   String
  quantity   Int      @default(0)
  imageUrl   String?
  medicine   Medicine @relation(fields: [medicineId], references: [id])
  vendor     Vendor   @relation(fields: [vendorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([medicineId, vendorId])
  @@index([updatedAt])
  @@index([vendorId, updatedAt])
}

model Order {
  id         String      @id @default(uuid())
  userId     String
  status     OrderStatus @default(PENDING)
  totalCents Int
  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]
  payment    Payment?
  invoice    Invoice?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  medicineId     String
  quantity       Int      @default(1)
  unitPriceCents Int
  order          Order    @relation(fields: [orderId], references: [id])
  medicine       Medicine @relation(fields: [medicineId], references: [id])

  @@index([orderId])
  @@index([medicineId])
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String        @unique
  provider    String
  status      PaymentStatus @default(INITIATED)
  amountCents Int
  order       Order         @relation(fields: [orderId], references: [id])
  createdAt   DateTime      @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([provider, createdAt])
}

model Invoice {
  id            String   @id @default(uuid())
  orderId       String   @unique
  invoiceNumber String   @unique
  issuedAt      DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id])
}

model ExchangeRate {
  baseCode  String   @id
  rates     Json
  fetchedAt DateTime
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
