# Frontend Environment Variables (.env.development)
# Used for local development
# Copy to .env for development or rename to .env.development for Vite

# API Configuration
VITE_API_URL=http://localhost:4000/api

# App Configuration
VITE_APP_NAME=MedBroker
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=true

# Note: For production, create .env.production with:
# VITE_API_URL=https://api.medbroker.com/api
# VITE_ENABLE_DEBUG=false
